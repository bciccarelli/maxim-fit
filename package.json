{
  "name": "protocol-app",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@10.8.2",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "dev:web": "turbo dev --filter=@protocol/web",
    "build:web": "turbo build --filter=@protocol/web"
  },
  "devDependencies": {
    "turbo": "^2.4.4"
  }
}
