{
  "cli": {
    "version": ">= 16.32.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_API_URL": "https://www.maxim.fit",
        "EXPO_PUBLIC_BYPASS_SUBSCRIPTION": "true"
      }
    },
    "preview": {
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_API_URL": "https://www.maxim.fit",
        "EXPO_PUBLIC_BYPASS_SUBSCRIPTION": "true"
      }
    },
    "production": {
      "autoIncrement": true,
      "env": {
        "EXPO_PUBLIC_API_URL": "https://www.maxim.fit",
        "EXPO_PUBLIC_BYPASS_SUBSCRIPTION": "true"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "appleTeamId": "WA55XYZPWQ"
      }
    }
  }
}